{
  "gitignore": true,
  "ignore": [
    "**/*.svg",
    "**/*cache*/**",
    "**/.git/**",
    "**/.github/**",
    "**/.idea/**",
    "**/.rbenv/**",
    "**/.venv/**",
    "**/node_modules/**",
    "**/openspec/**",
    "**/report/**",
    "**/tests/fixtures/**",
    "**/tests/perf/**"
  ],
  "reporters": ["html", "markdown"],
  "threshold": 25
}
